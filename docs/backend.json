
{
  "entities": {
    "Vendor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Vendor",
      "type": "object",
      "description": "Represents a street food vendor or stall that offers items through the Craving platform.",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "gstNumber": { "type": "string" },
        "fssaiNumber": { "type": "string" },
        "description": { "type": "string" },
        "locationDescription": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "qrCodeUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "ownerId", "name", "contactPhone", "createdAt", "updatedAt", "isActive"]
    },
    "MenuItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MenuItem",
      "type": "object",
      "description": "Represents a single food item or dish offered by a vendor on their digital menu.",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "isAvailable": { "type": "boolean" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "vendorId", "name", "description", "price", "isAvailable", "category", "createdAt", "updatedAt"]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer who places orders through the Craving platform.",
      "properties": {
        "id": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "phoneNumber", "createdAt", "updatedAt"]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "vendorId": { "type": "string" },
        "orderItemIds": { "type": "array", "items": { "type": "string" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "orderTime": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerId", "vendorId", "orderItemIds", "totalAmount", "status", "paymentStatus", "orderTime"]
    },
    "LoyaltyProgram": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LoyaltyProgram",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "isActive": { "type": "boolean" },
        "walletTiers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": { "type": "number" },
              "bonus": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "vendorId", "name", "description", "type", "isActive", "createdAt", "updatedAt"]
    },
    "CustomerWallet": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CustomerWallet",
      "type": "object",
      "description": "Stores bonus credits and prepaid balance for a customer at a specific vendor.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "vendorId": { "type": "string" },
        "balance": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerId", "vendorId", "balance", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/vendors/{vendorId}",
        "definition": { "entityName": "Vendor", "schema": { "$ref": "#/backend/entities/Vendor" }, "description": "Vendor profiles." }
      },
      {
        "path": "/vendors/{vendorId}/menuItems/{menuItemId}",
        "definition": { "entityName": "MenuItem", "schema": { "$ref": "#/backend/entities/MenuItem" }, "description": "Vendor menu items." }
      },
      {
        "path": "/vendors/{vendorId}/loyaltyPrograms/{loyaltyProgramId}",
        "definition": { "entityName": "LoyaltyProgram", "schema": { "$ref": "#/backend/entities/LoyaltyProgram" }, "description": "Marketing strategies." }
      },
      {
        "path": "/customers/{customerId}",
        "definition": { "entityName": "Customer", "schema": { "$ref": "#/backend/entities/Customer" }, "description": "Customer profiles." }
      },
      {
        "path": "/customers/{customerId}/wallets/{walletId}",
        "definition": { "entityName": "CustomerWallet", "schema": { "$ref": "#/backend/entities/CustomerWallet" }, "description": "Prepaid credits for a specific customer at a vendor." }
      }
    ]
  }
}
